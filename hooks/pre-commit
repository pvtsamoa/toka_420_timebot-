#!/bin/bash
# Pre-commit hook to prevent committing sensitive files
# Install this with: cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

echo "🔐 Running security pre-commit checks..."

# Check for .env files
if git diff --cached --name-only | grep -E "\.env|secrets\.|credentials\." > /dev/null; then
    echo "❌ ERROR: Attempted to commit sensitive files:"
    git diff --cached --name-only | grep -E "\.env|secrets\.|credentials\."
    echo ""
    echo "Sensitive files are not allowed. These are blocked by .gitignore."
    echo "If you accidentally added one, remove it with: git rm --cached <filename>"
    exit 1
fi

# Check for hardcoded credentials in staged files
echo "Scanning for hardcoded credentials..."
if git diff --cached -U0 | grep -E "TELEGRAM_BOT_TOKEN\s*=\s*[0-9]{3,}"|grep -v "YOUR_" > /dev/null; then
    echo "❌ ERROR: Hardcoded token detected in staged files!"
    echo "Use environment variables or .env file instead."
    exit 1
fi

# Check for password patterns
if git diff --cached -U0 | grep -E -i "(password|passwd|pwd|secret|api_key|token)\s*[:=]\s*['\"][^'\"]*['\"]" | grep -v "YOUR_" > /dev/null; then
    echo "⚠️  WARNING: Possible hardcoded credentials detected"
    echo "Please verify this is not a real secret before committing."
    read -p "Continue? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
fi

# Check for large files (potential compiled secrets/binaries)
LARGE_FILES=$(git diff --cached --name-only | while read FILE; do
    SIZE=$(git cat-file -s :0:$FILE 2>/dev/null)
    if [ ! -z "$SIZE" ] && [ "$SIZE" -gt 524288 ]; then
        echo "$FILE"
    fi
done)

if [ ! -z "$LARGE_FILES" ]; then
    echo "⚠️  WARNING: Large files detected (>500KB):"
    echo "$LARGE_FILES"
    echo "These could contain embedded secrets."
    read -p "Continue? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
fi

echo "✅ Security checks passed!"
exit 0
