# ── Required ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_GLOBAL_CHAT_ID=your_chat_id_here   # integer ID or @username

# ── Weedcoin OG (Solana) ──────────────────────────────────────────────────────
# $WEEDCOIN — Weedcoin OG on Solana — global cannabis culture coin (low THCV)
# Best practice: set WEEDCOIN_TOKEN to the exact Solana contract address so
# DexScreener returns the correct token and not a different chain's "weedcoin".
WEEDCOIN_TOKEN=weedcoin          # contract address OR search term
WEEDCOIN_CHAIN=solana            # chain to prefer when matching pairs

# ── Secondary token (any) ─────────────────────────────────────────────────────
# Set to any token symbol or contract address — BTC, SOL, BONK, etc.
SECONDARY_TOKEN=ethereum

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=America/Los_Angeles           # scheduler reference timezone (IANA format)

# ── TradingView HOB Webhook (Vercel deployment) ───────────────────────────────
# Set these in your Vercel project's Environment Variables dashboard.
# Webhook URL (no port, HTTPS): https://<your-app>.vercel.app/api/webhook/tradingview
WEBHOOK_SECRET=                  # shared secret — TradingView sends: Authorization: Bearer <secret>
                                 # leave blank to disable auth (not recommended in production)

# ── TradingView HOB Webhook (local / Docker fallback) ─────────────────────────
WEBHOOK_ENABLED=false            # set to true to start the local aiohttp receiver
WEBHOOK_PORT=8080                # port to listen on when running locally
