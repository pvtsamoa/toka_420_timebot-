# Toka 420 Timebot Environment Variables
# Copy this file to .env and fill in your actual values

# REQUIRED: Your Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# REQUIRED: Your Telegram channel or group chat ID
TELEGRAM_GLOBAL_CHAT_ID=your_chat_id_here

# OPTIONAL: Default cryptocurrency token id (coingecko/dex search)
DEFAULT_TOKEN=weedcoin

# OPTIONAL: Timezone for the bot
TZ=America/Los_Angeles
